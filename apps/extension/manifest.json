{
  "manifest_version": 3,
  "name": "shwdn2op",
  "version": "0.1.0",
  "description": "Showdown second opinion with local model CLIs and deterministic battle-state analysis.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "commands",
    "tabs"
  ],
  "host_permissions": [
    "https://play.pokemonshowdown.com/*",
    "https://pokemonshowdown.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "shwdn2op",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "commands": {
    "analyze-current-turn": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Show or hide the shwdn2op windows on Pokemon Showdown"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://pokemonshowdown.com/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://pokemonshowdown.com/*"
      ]
    }
  ]
}
