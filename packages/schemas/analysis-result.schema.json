{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "topChoiceActionId",
    "rankedActions",
    "assumptions",
    "dangerFlags",
    "confidence"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "maxLength": 500
    },
    "topChoiceActionId": {
      "type": "string"
    },
    "rankedActions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actionId",
          "label",
          "score",
          "rationale",
          "assumptions",
          "risks"
        ],
        "properties": {
          "actionId": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "rationale": {
            "type": "string",
            "maxLength": 400
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 5
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 5
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    },
    "dangerFlags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    },
    "toolsUsed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}